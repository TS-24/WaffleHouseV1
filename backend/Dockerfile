# ========================================
# Stage 1: Build the Java/Gradle Backend
# ========================================

FROM gradle:8.7-jdk21-alpine AS builder

WORKDIR /app

# Copy Gradle files and cache dependencies
COPY gradlew build.gradle settings.gradle* ./
COPY gradle/ ./gradle/

# Copy the source code
COPY src/ ./src/

# Compile and package the application
RUN gradle installDist --no-daemon

# ========================================
# Stage 2: Production Runtime
# ========================================

FROM eclipse-temurin:21-jre-alpine

WORKDIR /app

# Copy the compiled application from the builder
# NOTE: "backend" here corresponds to your Gradle root project name.
# If your settings.gradle names the project differently (e.g., "wafflehouse"), change this path.
COPY --from=builder /app/build/install/backend/ ./

EXPOSE 8080

# Execute the start script generated by the Gradle application plugin
CMD ["./bin/backend"]